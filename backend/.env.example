NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_ORIGIN=https://admin.sharpkode.com
CLIENT_ORIGINS=https://admin.sharpkode.com,https://portal.sharpkode.com

CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>
CLOUDINARY_FOLDER=sharpkode-workforce

OFFICE_LATITUDE=17.72861938927439
OFFICE_LONGITUDE=83.3146940456679
OFFICE_ALLOWED_RADIUS_METERS=100
